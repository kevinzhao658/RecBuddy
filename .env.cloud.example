# Cloud Supabase credentials for `npm run seed:cloud` (generates coach-app sample data on cloud).
# Copy to .env.cloud and fill from your Supabase dashboard → Project Settings → API.
# .env.cloud is gitignored. The service_role key is SECRET — never commit it.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service_role-secret-key>
